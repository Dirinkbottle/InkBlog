COMPOSE_PROJECT_NAME=inkblog
TZ=Asia/Shanghai

WEB_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=inkblog
MYSQL_USER=inkblog
MYSQL_PASSWORD=change-this-app-password

NOTIFICATION_SERVICE_TOKEN=inkblog-notification-prod-token
SERVICE_CONTROL_TOKEN=inkblog-service-control-prod-token
DEPLOY_PUSH_TOKEN=replace-with-long-random-token
DEPLOY_RELEASE_ROOT=/app/release
CORE_CONTROL_PORT=13170
NPM_REGISTRY=https://registry.npmmirror.com/

# GitHub Release sync (required)
GH_RELEASE_REPO=your-org-or-user/InkBlog
GH_RELEASE_TAG=deploy-latest
GH_RELEASE_TOKEN=
GH_RELEASE_BACKEND_ASSET=backend_bundle.tar.gz
GH_RELEASE_BACKEND_SHA_ASSET=backend_bundle.tar.gz.sha256
GH_RELEASE_WEB_ASSET=web_bundle.tar.gz
GH_RELEASE_WEB_SHA_ASSET=web_bundle.tar.gz.sha256
